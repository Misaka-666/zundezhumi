/* 猜猫猫游戏页样式 */
.guess-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fffdf5 0%, #f7f7fa 40%);
}

/* ===== 加载中 ===== */
.guess-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 300rpx;
}

.loading-cat {
  font-size: 120rpx;
  animation: bounce 1s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.loading-text {
  margin-top: 30rpx;
  font-size: 30rpx;
  color: var(--color-gray-max);
}

/* ===== 错误 / 猫数不足 ===== */
.guess-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 300rpx;
}

.error-icon {
  font-size: 120rpx;
}

.error-text {
  margin-top: 20rpx;
  font-size: 30rpx;
  color: var(--color-gray-max);
  text-align: center;
  line-height: 1.6;
  padding: 0 60rpx;
}

/* ===== 答题中 ===== */
.guess-playing {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quiz-header {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.quiz-progress {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-black-light);
  letter-spacing: 2rpx;
}

.quiz-score {
  font-size: 28rpx;
  color: var(--color-gray-max);
}

.score-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary-text);
  margin-left: 6rpx;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: var(--color-gray-normal);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 36rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-dark));
  border-radius: 6rpx;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ===== 揭晓卡片 ===== */
.photo-card {
  width: 100%;
  height: 520rpx;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0rpx 16rpx 40rpx rgba(0, 0, 0, 0.12), 0rpx 4rpx 12rpx rgba(255, 209, 1, 0.15);
  background: var(--color-gray-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 44rpx;
}

/* 入场：模糊→清晰揭晓（每题切回 entering 时触发） */
.photo-card.entering {
  animation: revealIn 0.5s ease-out;
}

@keyframes revealIn {
  0% { filter: blur(20px); opacity: 0.3; transform: scale(0.95); }
  60% { filter: blur(3px); opacity: 0.9; }
  100% { filter: blur(0); opacity: 1; transform: scale(1); }
}

.cat-photo {
  width: 100%;
  height: 100%;
}

.photo-placeholder {
  font-size: 28rpx;
  color: var(--color-gray-max);
}

/* 光晕层 */
.photo-glow {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(circle at 50% 40%, rgba(255, 209, 1, 0.08), transparent 60%);
  pointer-events: none;
  z-index: 2;
}

/* 答题后揭晓动效 */
.photo-card.revealed {
  animation: revealPulse 0.5s ease-out;
}

@keyframes revealPulse {
  0% { transform: scale(1); }
  40% { transform: scale(1.03); box-shadow: 0rpx 20rpx 50rpx rgba(0, 0, 0, 0.18); }
  100% { transform: scale(1); }
}

/* 对/错浮层徽章 */
.photo-badge {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%) scale(0);
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  font-weight: 700;
  color: #fff;
  z-index: 10;
  animation: badgePop 0.4s ease-out 0.1s forwards;
}

.badge-correct {
  background: var(--color-green);
  box-shadow: 0rpx 8rpx 30rpx rgba(34, 173, 109, 0.5);
}

.badge-wrong {
  background: var(--color-red);
  box-shadow: 0rpx 8rpx 30rpx rgba(220, 53, 69, 0.5);
}

@keyframes badgePop {
  0% { transform: translate(-50%, -50%) scale(0); opacity: 0; }
  60% { transform: translate(-50%, -50%) scale(1.2); opacity: 1; }
  100% { transform: translate(-50%, -50%) scale(1); opacity: 0.95; }
}

/* ===== 选项 ===== */
.options {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.option {
  width: 48%;
  margin-bottom: 24rpx;
  padding: 30rpx 0;
  text-align: center;
  font-size: 34rpx;
  font-weight: 500;
  color: var(--color-black-light);
  background: #fff;
  border: 3rpx solid var(--color-gray);
  border-radius: 20rpx;
  box-shadow: 0rpx 4rpx 14rpx var(--color-ltblack-transparent);
  transition: all 0.2s ease;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 1rpx;
}

.option:active {
  transform: scale(0.96);
}

/* 答对：弹跳 + 绿色高亮 */
.option.correct {
  background: var(--color-green);
  color: #fff;
  border-color: var(--color-green-dark);
  animation: correctBounce 0.5s ease-out;
  box-shadow: 0rpx 6rpx 20rpx rgba(34, 173, 109, 0.4);
}

@keyframes correctBounce {
  0% { transform: scale(1); }
  30% { transform: scale(1.08); }
  50% { transform: scale(0.96); }
  70% { transform: scale(1.03); }
  100% { transform: scale(1); }
}

/* 答错：摇晃 + 红色高亮 */
.option.wrong {
  background: var(--color-red);
  color: #fff;
  border-color: var(--color-red-dark);
  animation: wrongShake 0.4s ease-out;
  box-shadow: 0rpx 6rpx 20rpx rgba(220, 53, 69, 0.4);
}

@keyframes wrongShake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-12rpx); }
  40% { transform: translateX(10rpx); }
  60% { transform: translateX(-8rpx); }
  80% { transform: translateX(6rpx); }
}

/* ===== 结算页 —— 成绩卡片 ===== */
.guess-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 120rpx;
  width: 100%;
}

.result-card {
  width: 100%;
  background: #fff;
  border-radius: 28rpx;
  padding: 50rpx 40rpx 40rpx;
  box-shadow: 0rpx 16rpx 48rpx rgba(0, 0, 0, 0.1), 0rpx 4rpx 16rpx rgba(255, 209, 1, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: cardSlideIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes cardSlideIn {
  0% { transform: translateY(40rpx) scale(0.9); opacity: 0; }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}

/* 环形进度 */
.result-ring {
  position: relative;
  width: 220rpx;
  height: 220rpx;
  margin-bottom: 30rpx;
}

.ring-bg, .ring-fill {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.ring-bg {
  background: var(--color-gray-normal);
}

.ring-fill {
  animation: ringDraw 0.8s ease-out forwards;
}

@keyframes ringDraw {
  0% { transform: rotate(-90deg) scale(0.8); opacity: 0; }
  100% { transform: rotate(0deg) scale(1); opacity: 1; }
}

.ring-center {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.ring-score {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--color-primary-text);
}

.ring-total {
  font-size: 32rpx;
  color: var(--color-gray-max);
  margin-left: 4rpx;
}

/* 评级 */
.result-rank {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-black-light);
  margin-bottom: 12rpx;
}

.result-rank-desc {
  font-size: 28rpx;
  color: var(--color-gray-max);
  text-align: center;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.result-newbest {
  font-size: 30rpx;
  color: var(--color-green-dark);
  font-weight: 600;
  margin-bottom: 8rpx;
  animation: newBestPulse 0.6s ease-out 0.3s;
}

@keyframes newBestPulse {
  0% { transform: scale(0.8); opacity: 0; }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}

.result-best {
  font-size: 28rpx;
  color: var(--color-gray-max);
}

.best-num {
  font-weight: 700;
  color: var(--color-primary-text);
  margin-left: 6rpx;
}

/* 提交状态 */
.submit-status {
  margin-top: 16rpx;
  font-size: 26rpx;
  text-align: center;
}

.submit-status.submitting {
  color: var(--color-gray-max);
}

.submit-status.success {
  color: var(--color-green-dark);
}

.submit-status.fail {
  color: var(--color-gray-max);
}

/* 按钮 */
.result-btns {
  margin-top: 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.btn-restart {
  width: 80%;
  padding: 28rpx 0;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-onPrimary);
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  border-radius: 44rpx;
  margin-bottom: 24rpx;
  box-shadow: 0rpx 8rpx 24rpx rgba(255, 209, 1, 0.4);
}

.btn-restart:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-back {
  width: 80%;
  padding: 28rpx 0;
  text-align: center;
  font-size: 34rpx;
  color: var(--color-black-light);
  background: #fff;
  border: 2rpx solid var(--color-gray);
  border-radius: 44rpx;
}

.btn-back:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* ===== 模式选择页 ===== */
.guess-select {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
}

.select-title {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-black-light);
  margin-bottom: 16rpx;
}

.select-subtitle {
  font-size: 30rpx;
  color: var(--color-gray-max);
  margin-bottom: 50rpx;
}

.mode-cards {
  width: 100%;
  display: flex;
  flex-direction: column;
}

.mode-card {
  display: flex;
  align-items: center;
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 28rpx;
  box-shadow: 0rpx 8rpx 24rpx var(--color-ltblack-transparent);
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.mode-card:active {
  transform: scale(0.97);
  border-color: var(--color-primary);
  box-shadow: 0rpx 8rpx 30rpx rgba(255, 209, 1, 0.3);
}

.mode-icon {
  font-size: 60rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.mode-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.mode-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-black-light);
  margin-bottom: 8rpx;
}

.mode-desc {
  font-size: 26rpx;
  color: var(--color-gray-max);
  line-height: 1.4;
}

.mode-best {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-primary-text);
  background: var(--color-primary-light);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

/* ===== 限时模式倒计时 ===== */
.quiz-progress.time-urgent {
  color: var(--color-red);
  animation: timeBlink 0.5s infinite;
}

@keyframes timeBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.progress-fill.time-urgent {
  background: linear-gradient(90deg, var(--color-red), var(--color-red-dark));
}

/* 无限模式连胜渐变条 */
.endless-fill {
  background: linear-gradient(90deg, #ff6b35, #ff9500);
}

/* ===== 无限模式结算：连胜大字 ===== */
.result-streak {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.streak-num {
  font-size: 100rpx;
  font-weight: 700;
  color: #ff6b35;
  line-height: 1.1;
  animation: streakPop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes streakPop {
  0% { transform: scale(0.3); opacity: 0; }
  60% { transform: scale(1.15); }
  100% { transform: scale(1); opacity: 1; }
}

.streak-label {
  font-size: 30rpx;
  color: var(--color-gray-max);
  margin-top: 8rpx;
}

/* ===== 限时模式结算：答对数 ===== */
.result-timed {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.timed-score {
  font-size: 100rpx;
  font-weight: 700;
  color: var(--color-primary-text);
  line-height: 1.1;
  animation: streakPop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.timed-info {
  font-size: 28rpx;
  color: var(--color-gray-max);
  margin-top: 8rpx;
}

/* ===== 返回选择页按钮 ===== */
.btn-select {
  width: 80%;
  padding: 28rpx 0;
  text-align: center;
  font-size: 34rpx;
  color: var(--color-black-light);
  background: #fff;
  border: 2rpx solid var(--color-gray);
  border-radius: 44rpx;
}

.btn-select:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 排行榜入口按钮 */
.select-rank-btn {
  margin-top: 40rpx;
  padding: 24rpx 60rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary-text);
  background: #fff;
  border: 3rpx solid var(--color-primary);
  border-radius: 44rpx;
  box-shadow: 0rpx 4rpx 16rpx rgba(255, 209, 1, 0.2);
}

.select-rank-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 结算页排行榜按钮 */
.btn-rank {
  width: 80%;
  padding: 24rpx 0;
  text-align: center;
  font-size: 32rpx;
  color: var(--color-primary-text);
  background: var(--color-primary-light);
  border: 2rpx solid var(--color-primary);
  border-radius: 44rpx;
  margin-top: 8rpx;
}

.btn-rank:active {
  opacity: 0.85;
  transform: scale(0.98);
}
