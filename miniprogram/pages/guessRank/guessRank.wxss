/* 猜猫猫排行榜样式 */
.rank-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #fffdf5 0%, #f7f7fa 40%);
}

/* Tab */
.rank-tabs {
  display: flex;
  background: #fff;
  box-shadow: 0rpx 4rpx 12rpx var(--color-ltblack-transparent);
  position: sticky;
  top: 0;
  z-index: 10;
}

.rank-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-gray-max);
  border-bottom: 4rpx solid transparent;
  transition: all 0.2s ease;
}

.rank-tab.active {
  color: var(--color-primary-text);
  font-weight: 700;
  border-bottom-color: var(--color-primary);
}

/* 加载 */
.rank-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 200rpx;
}

.loading-cat {
  font-size: 100rpx;
  animation: bounce 1s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: var(--color-gray-max);
}

/* 列表 */
.rank-scroll {
  flex: 1;
  height: calc(100vh - 200rpx);
}

.rank-item {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 10rpx 20rpx;
  padding: 24rpx 30rpx;
  border-radius: 16rpx;
  box-shadow: 0rpx 2rpx 10rpx var(--color-ltblack-transparent);
}

/* Top 3 特殊样式 */
.rank-item.top-1 {
  background: linear-gradient(135deg, #fff9e6, #fff);
  border: 2rpx solid rgba(255, 209, 1, 0.4);
}

.rank-item.top-2 {
  background: linear-gradient(135deg, #f8f8f8, #fff);
  border: 2rpx solid rgba(200, 200, 200, 0.3);
}

.rank-item.top-3 {
  background: linear-gradient(135deg, #fff5ee, #fff);
  border: 2rpx solid rgba(205, 127, 50, 0.25);
}

.rank-num {
  width: 60rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-gray-max);
  flex-shrink: 0;
}

.rank-item.top-1 .rank-num { color: #e6a800; }
.rank-item.top-2 .rank-num { color: #999; }
.rank-item.top-3 .rank-num { color: #cd7f32; }

.rank-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin: 0 24rpx;
  flex-shrink: 0;
  background: var(--color-gray-light);
}

.rank-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-black-light);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-score {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary-text);
  flex-shrink: 0;
}

.rank-unit {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--color-gray-max);
  margin-left: 4rpx;
}

/* 空榜 */
.rank-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: var(--color-gray-max);
  text-align: center;
}

/* 底部我的排名 */
.rank-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0rpx -4rpx 16rpx var(--color-ltblack-transparent);
  display: flex;
  justify-content: center;
  z-index: 10;
}

.my-rank {
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.my-rank-label {
  color: var(--color-gray-max);
  margin-right: 12rpx;
}

.my-rank-num {
  font-weight: 700;
  color: var(--color-primary-text);
  margin-right: 16rpx;
}

.my-rank-best {
  color: var(--color-gray-max);
}
